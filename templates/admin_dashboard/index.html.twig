{# templates/admin/reports/monthly.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block body_custom_vars %}
    --content-max-width: 100%; 
{% endblock %}

{% block head_stylesheets %}
    {{ parent() }}
    <style>
        .content-wrapper { padding: 0 !important; margin: 0 !important; }
        .content { max-width: 100% !important; padding: 2rem !important; background-color: white;}

        .hover-lift {
            transition: transform 0.2s ease-in-out, shadow 0.2s ease-in-out;
            cursor: pointer;
        }

        .hover-lift:hover {
            transform: translateY(-10px); /* This "raises" it up */
            box-shadow: 0 10px 20px rgba(81, 171, 255, 0.555) !important; /* Adds a shadow depth */
            background-color: rgb(255, 255, 255) !important;
        }
    </style>
{% endblock %}

{% block content_title %}
    <i class="fa fa-chart-line"></i> Loan App Dashboard
{% endblock %}

{% block main %}
    <div class="card shadow-sm p-4">
        <h4>Key Perfomance Indicators for {{ currentMonth }}</h4>
        <hr>
        
        <div class="row">
            <!-- Card 1 -->
            <div class="col-md-3">
                <a href="">
                <div class="alert alert-info h-100 mb-0 hover-lift"> <!-- h-100 forces equal height -->
                    <h6 class="text-uppercase small fw-bold">Total Loans Issued</h6>
                    <p class="h3 mb-0">{{ adminKPI.total_loans }}</p>
                </div>
                </a>
            </div>
            
            <!-- Card 2 -->
            <div class="col-md-3">
                <a href="">
                <div class="alert alert-success h-100 mb-0 hover-lift">
                    <h6 class="text-uppercase small fw-bold">Total Active Loans</h6>
                    <p class="h3 mb-0">{{ adminKPI.active_loans|number_format(0) }}</p>
                </div>
                </a>
            </div>

            <!-- Card 3 -->
            <div class="col-md-3">
                <a href="#">
                <div class="alert alert-info h-100 mb-0 hover-lift">
                    <h6 class="text-uppercase small fw-bold">Total Overdue Loans</h6>
                    <p class="h3 mb-0">{{ adminKPI.overdue_loans|number_format(0) }}</p>
                </div>
                </a>
            </div>

            <!-- Card 4 -->
            <div class="col-md-3">
                <a href="">
                <div class="alert alert-success h-100 mb-0 hover-lift">
                    <h6 class="text-uppercase small fw-bold">Total Closed Loans</h6>
                    <p class="h3 mb-0">{{ adminKPI.closed_loans|number_format(0) }}</p>
                </div>
                </a>
            </div>
        </div>
        <br>
        <div class="card shadow-sm p-2 mt-2">
            <h5>Loan Trends</h5>
            
            <!-- The Row wrapper makes items sit side-by-side -->
            <div class="row">
                <div class="col-md-8">
                    {{ render_chart(chart) }}
                </div>
                <div class="col-md-4">
                    {{ render_chart(chart2) }}
                </div>
                
            </div>
        </div>
        <table class="table mt-4">
            <thead>
                <tr>
                    <th>Metric</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                {% for metric, value in adminKPI %}
                    <tr class="hover-lift">
                        <td>{{ metric }}</td>
                        <td>{{ value|number_format(2) }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
