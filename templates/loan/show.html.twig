{% extends 'base.html.twig' %}

{% block title %}Loan{% endblock %}

{% block body %}
    <h1>Loan</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ loan.id }}</td>
            </tr>
            <tr>
                <th>Amount</th>
                <td>{{ loan.amount }}</td>
            </tr>
            <tr>
                <th>Interest_percent</th>
                <td>{{ loan.interestPercent }}</td>
            </tr>
            <tr>
                <th>Interest_amount</th>
                <td>{{ loan.interestAmount }}</td>
            </tr>
            <tr>
                <th>Total_payback</th>
                <td>{{ loan.totalPayback }}</td>
            </tr>
            <tr>
                <th>Balance_remaining</th>
                <td>{{ loan.balanceRemaining }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ loan.createdAt ? loan.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_loan_index') }}">back to list</a>

    <a href="{{ path('app_loan_edit', {'id': loan.id}) }}">edit</a>

    {{ include('loan/_delete_form.html.twig') }}
{% endblock %}
