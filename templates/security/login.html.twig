{% extends 'base.html.twig' %}

{% block body %}
{# 1. Centering Container with a deep blue background #}
<div class="min-h-screen flex items-center justify-center bg-gradient-to-tr from-blue-900 via-indigo-900 to-blue-800 p-4">
    
    {# 2. The Semi-Transparent Card #}
    <div class="w-full max-w-md bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl shadow-2xl overflow-hidden p-8">
        
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-white tracking-tight">Login</h1>
            <p class="text-blue-200 mt-2">Welcome back! Please enter your details.</p>
        </div>

        {% if error %}
            <div class="mb-6 p-4 rounded-lg bg-red-500/20 border border-red-500/40 text-red-100 text-sm text-center">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form action="{{ path('app_login') }}" method="post" class="space-y-5">
            {# Email Field #}
            <div>
                <label for="username" class="block text-sm font-medium text-blue-100 mb-1.5 ml-1">Email</label>
                <input type="text" id="username" name="email" value="{{ last_username }}" 
                    class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-xl focus:ring-2 focus:ring-blue-400 focus:bg-white/10 text-white placeholder-blue-300/50 outline-none transition-all"
                    placeholder="name@company.com" required autofocus>
            </div>

            {# Password Field #}
            <div>
                <label for="password" class="block text-sm font-medium text-blue-100 mb-1.5 ml-1">Password</label>
                <input type="password" id="password" name="password" 
                    class="w-full px-4 py-3 bg-white/5 border border-white/20 rounded-xl focus:ring-2 focus:ring-blue-400 focus:bg-white/10 text-white outline-none transition-all"
                    required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {# Submit Button #}
            <button type="submit" 
                class="w-full py-3 bg-white text-blue-900 hover:bg-blue-50 font-bold rounded-xl shadow-lg transition-all active:scale-95 mt-4">
                Sign In
            </button>
        </form>

        <div class="mt-8 text-center border-t border-white/10 pt-6">
            <a href="#" class="text-sm text-blue-200 hover:text-white transition">Forgot password?</a>
        </div>
    </div>
</div>
{% endblock %}
