{% extends 'base.html.twig' %}

{% block title %}HistoryCustomers index{% endblock %}

{% block body %}
    <h1>HistoryCustomers index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Notes</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for history_customer in history_customers %}
            <tr>
                <td>{{ history_customer.id }}</td>
                <td>{{ history_customer.notes }}</td>
                <td>
                    <a href="{{ path('app_history_customers_show', {'id': history_customer.id}) }}">show</a>
                    <a href="{{ path('app_history_customers_edit', {'id': history_customer.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_history_customers_new') }}">Create new</a>
{% endblock %}
