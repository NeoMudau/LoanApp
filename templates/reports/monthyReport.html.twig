{# templates/admin/reports/monthly.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block body_custom_vars %}
    --content-max-width: 100%; 
{% endblock %}

{% block head_stylesheets %}
    {{ parent() }}
    <style>
        .content-wrapper { padding: 0 !important; margin: 0 !important; }
        .content { max-width: 100% !important; padding: 2rem !important; background-color: white;}
    </style>
{% endblock %}

{% block content_title %}
    <i class="fa fa-chart-line"></i> Monthly Financial Report
{% endblock %}

{% block main %}
    <div class="card shadow-sm p-4">
        <h4>Performance for {{ stats.month }}</h4>
        <hr>
        
        <div class="row">
            <div class="col-md-6">
                <div class="alert alert-info">
                    <h5>New Loans Issued</h5>
                    <p class="display-6">{{ stats.new_loans }}</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="alert alert-success">
                    <h5>Total Collected</h5>
                    <p class="display-6">R {{ stats.collected_amount|number_format(2) }}</p>
                </div>
            </div>
        </div>

        <table class="table mt-4">
            <thead>
                <tr>
                    <th>Metric</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Target Reach</td>
                    <td>85%</td>
                </tr>
            </tbody>
        </table>
        <br>
        <div class="card shadow-sm p-2 mt-2">
            <h5>Loan Trends</h5>
            
            <!-- The Row wrapper makes items sit side-by-side -->
            <div class="row">
                
                <!-- First Chart (6 out of 12 columns = 50%) -->
                <div class="col-md-8">
                    {{ render_chart(chart) }}
                </div>

                <!-- Second Chart (6 out of 12 columns = 50%) -->
                <div class="col-md-4">
                    {{ render_chart(chart2) }}
                </div>
                
            </div>
        </div>
    </div>
{% endblock %}
