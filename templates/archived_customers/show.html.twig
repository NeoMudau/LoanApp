{% extends 'base.html.twig' %}

{% block title %}ArchivedCustomers{% endblock %}

{% block body %}
    <h1>ArchivedCustomers</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ archived_customer.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ archived_customer.name }}</td>
            </tr>
            <tr>
                <th>Reason_archived</th>
                <td>{{ archived_customer.reasonArchived }}</td>
            </tr>
            <tr>
                <th>Date_archived</th>
                <td>{{ archived_customer.dateArchived ? archived_customer.dateArchived|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_archived_customers_index') }}">back to list</a>

    <a href="{{ path('app_archived_customers_edit', {'id': archived_customer.id}) }}">edit</a>

    {{ include('archived_customers/_delete_form.html.twig') }}
{% endblock %}
